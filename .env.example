# DeepSeek API Key（可选，不填则使用 mock 数据）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址（默认：https://api.deepseek.com/v1）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 应用配置
APP_NAME=Amazon Seller AI Dashboard
APP_VERSION=1.0.0

# 业务配置：1 美元可兑换的人民币金额
USD_CNY_RATE=7.2

# 数据库地址（不填时使用项目根目录下的 SQLite）
# DATABASE_URL=sqlite:///amazon_dashboard.db
